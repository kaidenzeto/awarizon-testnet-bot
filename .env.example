# Awarizon secrets — NEVER commit this file
# Copy to .env and fill in your values

# Private key (with or without 0x prefix)
# Multi-wallet: comma-separated keys
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Referral code (optional, leave blank to skip)
REFERRAL_CODE=

# Social usernames for auto-connect (optional)
# Uncomment and fill to auto-connect on --action auto
# TWITTER_USERNAME=yourhandle
# TELEGRAM_USERNAME=yourname
# DISCORD_USERNAME=yourname
